{
  "name": "chen-ting-todo",
  "version": "1.0.0",
  "description": "Think Less. Do More. — Digital Garden & Tech Blog",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "pagefind --site out",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/markdown-security.test.ts tests/article-pipeline.test.ts",
    "check:content": "tsx scripts/article-tool.ts check --published",
    "article:prepare": "tsx scripts/article-tool.ts prepare",
    "article:check": "tsx scripts/article-tool.ts check",
    "article:preview": "tsx scripts/article-preview.ts",
    "article:publish": "tsx scripts/article-tool.ts publish",
    "article:online": "tsx scripts/article-tool.ts online",
    "monitor:postcss": "node scripts/check-next-postcss.mjs",
    "check": "npm run lint && npm run typecheck && npm test && npm run check:content && npm run build"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "^15.5.20",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "unified": "^11.0.4"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.38.0",
    "eslint-config-next": "^15.5.20",
    "pagefind": "^1.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.23.1",
    "typescript": "^5.4.0"
  }
}
